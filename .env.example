# Backend base URL (no trailing slash)
VITE_API_BASE_URL=http://localhost:8080

# Employee Basic Auth credentials
VITE_EMPLOYEE_USERNAME=employee
VITE_EMPLOYEE_PASSWORD=changeme

# Employee ID sent as X-EMPLOYEE-ID header on employee endpoints
VITE_EMPLOYEE_ID=1

# Admin Basic Auth credentials
VITE_ADMIN_USERNAME=admin
VITE_ADMIN_PASSWORD=changeme
