# Backend base URL. Leave empty when nginx proxies /api/ internally (Docker deployment).
# Set to an absolute URL (e.g. https://api.yourdomain.com) only for non-proxied deployments.
VITE_API_BASE_URL=

# Keycloak - required, no defaults
VITE_KEYCLOAK_URL=https://auth.yourdomain.com
VITE_KEYCLOAK_REALM=wms
VITE_KEYCLOAK_CLIENT_ID=wms-client
